{
  "name": "healify",
  "version": "0.1.0",
  "description": "CLI for Healify — trigger tests, stream results, and manage projects from the terminal.",
  "bin": {
    "healify": "./dist/healify.js"
  },
  "scripts": {
    "build": "esbuild src/healify.ts --bundle --platform=node --target=node18 --outfile=dist/healify.js --external:node:*",
    "dev": "ts-node -T src/healify.ts"
  },
  "keywords": ["healify", "test", "automation", "healing", "playwright", "cypress"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  }
}
