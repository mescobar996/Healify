# =============================================================================
#  HEALIFY — Variables de entorno
#  Copiá este archivo a .env.local para desarrollo local.
#  En producción configurá cada variable directamente en Railway.
#  NUNCA commitees .env.local al repositorio.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  APP
# ─────────────────────────────────────────────────────────────────────────────

# URL pública de la app (sin barra final)
# Local: http://localhost:3000
# Producción: tu dominio en Railway o Vercel
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Igual que NEXT_PUBLIC_APP_URL — usado por NextAuth internamente
NEXTAUTH_URL=http://localhost:3000

# Secret de sesión para NextAuth.
# Generarlo con: openssl rand -base64 32
NEXTAUTH_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
#  BASE DE DATOS (Neon / PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────

# Cadena de conexión PostgreSQL.
# En Railway: pestaña "Neon" o "Postgres" → Connect → copiar Connection String.
# Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/healify?sslmode=require


# ─────────────────────────────────────────────────────────────────────────────
#  REDIS
# ─────────────────────────────────────────────────────────────────────────────

# URL de conexión Redis.
# En Railway: servicio Redis → Connect → copiar la URL.
# Formato: redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379


# ─────────────────────────────────────────────────────────────────────────────
#  AUTENTICACIÓN — GitHub OAuth
# ─────────────────────────────────────────────────────────────────────────────

# Crear en: https://github.com/settings/developers → "New OAuth App"
# Authorization callback URL: https://TU_DOMINIO/api/auth/callback/github
#
# GITHUB_ID   → "Client ID" de la OAuth App
# GITHUB_SECRET → "Generate a new client secret"
GITHUB_ID=
GITHUB_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
#  GITHUB WEBHOOK (worker de eventos de repos)
# ─────────────────────────────────────────────────────────────────────────────

# Secret que GitHub incluye en cada webhook para verificar la firma.
# Generarlo con: openssl rand -hex 32
# Configurarlo en: repo → Settings → Webhooks → Secret
GITHUB_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
#  SEGURIDAD — Cifrado de API Keys de usuarios
# ─────────────────────────────────────────────────────────────────────────────

# Clave AES de 32 bytes en hex para cifrar las API keys almacenadas.
# REQUERIDO en producción — sin esto las keys no se cifran correctamente.
# Generarlo con: openssl rand -hex 32
ENCRYPTION_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  CRON / WORKERS
# ─────────────────────────────────────────────────────────────────────────────

# Bearer token para proteger los endpoints internos:
#   - POST /api/cron/dispatch       (scheduler de test runs)
#   - POST /api/billing/setup-mp-plans  (setup inicial de MercadoPago)
# Generarlo con: openssl rand -hex 32
CRON_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
#  LEMON SQUEEZY — Pagos en USD (pasarela principal internacional)
# ─────────────────────────────────────────────────────────────────────────────

# PASO 1 — API Key
#   Ir a: https://app.lemonsqueezy.com/settings/api
#   → "New API key" → nombre "Healify Production" → copiar el token (empieza con "eyJ")
LEMONSQUEEZY_API_KEY=

# PASO 2 — Store ID
#   Ir a: https://app.lemonsqueezy.com → tu store → Settings → General
#   El ID aparece en la URL: app.lemonsqueezy.com/stores/XXXX  →  XXXX
LEMONSQUEEZY_STORE_ID=

# PASO 3 — Webhook Secret
#   Ir a: https://app.lemonsqueezy.com/webhooks → "Add webhook"
#   URL del webhook: https://TU_DOMINIO/api/webhook/lemonsqueezy
#   Eventos a marcar: subscription_created, subscription_updated,
#     subscription_cancelled, subscription_expired, subscription_resumed, order_created
#   → Click "Generate" en Signing Secret → copiar el valor
LEMONSQUEEZY_WEBHOOK_SECRET=

# PASO 4 — Variant IDs de cada plan
#   Ir a: https://app.lemonsqueezy.com/products → abrir cada producto
#   Pestaña "Variants" → copiar el ID numérico de la variante mensual
#
#   Crear 3 productos si no existen:
#     Healify Starter    → $49 USD / month  (Recurring)
#     Healify Pro        → $99 USD / month  (Recurring)
#     Healify Enterprise → $499 USD / month (Recurring)
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_ENTERPRISE_VARIANT_ID=


# ─────────────────────────────────────────────────────────────────────────────
#  MERCADOPAGO — Pagos en ARS (pasarela para Argentina)
# ─────────────────────────────────────────────────────────────────────────────

# PASO 1 — Access Token de PRODUCCIÓN
#   Ir a: https://www.mercadopago.com.ar/developers/panel/app
#   Seleccionar (o crear) tu aplicación → "Credenciales de producción"
#   → Copiar el "Access token" (empieza con "APP_USR-")
#   ⚠️  Usar credenciales de PRODUCCIÓN, no de prueba
MERCADOPAGO_ACCESS_TOKEN=

# PASO 2 — Webhook Secret
#   Es un string aleatorio que vos elegís. MercadoPago lo usará para firmar
#   las notificaciones con HMAC-SHA256.
#   Generarlo con: openssl rand -hex 32
#   Después configurarlo en:
#     https://www.mercadopago.com.ar/developers/panel/webhooks
#     → "Configurar notificaciones" → URL: https://TU_DOMINIO/api/webhook/mercadopago
#     → Activar: "Suscripciones" (subscription_preapproval, subscription_authorized_payment)
MERCADOPAGO_WEBHOOK_SECRET=

# PASO 3 — Plan IDs (se crean UNA SOLA VEZ después del deploy)
#   Una vez que MERCADOPAGO_ACCESS_TOKEN y CRON_SECRET estén en Railway
#   y el deploy esté listo, ejecutar:
#
#     curl -X POST https://TU_DOMINIO/api/billing/setup-mp-plans \
#       -H "Authorization: Bearer TU_CRON_SECRET"
#
#   La respuesta incluye los 3 IDs. Copiarlos aquí y hacer redeploy.
MERCADOPAGO_STARTER_PLAN_ID=
MERCADOPAGO_PRO_PLAN_ID=
MERCADOPAGO_ENTERPRISE_PLAN_ID=


# ─────────────────────────────────────────────────────────────────────────────
#  STRIPE — Legacy (mantener para suscriptores existentes migrados de Stripe)
# ─────────────────────────────────────────────────────────────────────────────

# Si no tenés suscriptores de Stripe, podés dejar estos en blanco.
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=


# ─────────────────────────────────────────────────────────────────────────────
#  EMAIL TRANSACCIONAL (Resend)
# ─────────────────────────────────────────────────────────────────────────────

# Obtener en: https://resend.com/api-keys → "Create API Key"
RESEND_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  OpenAI (AI healing)
# ─────────────────────────────────────────────────────────────────────────────

# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
