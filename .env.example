# ============================================
# HEALIFY — Environment Variables Example
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================

# ── Database (required) ──────────────────────
DATABASE_URL=postgresql://user:password@host:5432/healify

# ── Auth (required) ──────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── GitHub OAuth (required) ──────────────────
# Create at: https://github.com/settings/developers
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

# ── GitHub Webhook (required for worker) ─────
GITHUB_WEBHOOK_SECRET=your-random-webhook-secret

# ── Redis (required for worker queue) ────────
REDIS_URL=redis://localhost:6379

# ── Public URL ───────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe (optional — legacy, mantener para suscriptores existentes) ──
# Test keys at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Lemon Squeezy (pagos USD — nueva pasarela) ────────────
# API key: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=eyJ...
# Store ID: https://app.lemonsqueezy.com → tu store → Settings → General
LEMONSQUEEZY_STORE_ID=12345
# Webhook secret: https://app.lemonsqueezy.com/webhooks → crear webhook → copiar Secret
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs: Products → producto → Variants → ID numérico de cada variante
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_ENTERPRISE_VARIANT_ID=

# ── MercadoPago (pagos ARS — nueva pasarela) ──────────────
# Access Token: https://www.mercadopago.com.ar/developers/panel/app
# → Credenciales de PRODUCCIÓN → Access token
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# Secret aleatorio para verificar webhooks: openssl rand -hex 32
MERCADOPAGO_WEBHOOK_SECRET=
# Plan IDs: correr POST /api/billing/setup-mp-plans una sola vez para obtenerlos
MERCADOPAGO_STARTER_PLAN_ID=
MERCADOPAGO_PRO_PLAN_ID=
MERCADOPAGO_ENTERPRISE_PLAN_ID=

# ── Resend (optional — transactional email) ───
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Encryption — REQUERIDO en producción ─────────────────
# Generá con: openssl rand -hex 32
# Sin esto, las API keys de usuarios no se cifran correctamente
ENCRYPTION_KEY=

# ── Cron / Workers ────────────────────────────────────────
# Generá con: openssl rand -hex 32
# Usado por /api/cron/dispatch y /api/billing/setup-mp-plans
CRON_SECRET=
